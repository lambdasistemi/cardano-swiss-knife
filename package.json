{
  "name": "@lambdasistemi/cardano-swiss-knife",
  "version": "0.1.1",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": "./node/dist/index.js"
  },
  "files": [
    "node/dist"
  ],
  "scripts": {
    "build:lib": "npx spago build -p cardano-addresses",
    "test": "npx spago test -p cardano-addresses-test",
    "bundle:lib": "npx esbuild output/Cardano.Address/index.js --bundle --outfile=dist/cardano-addresses.js --format=esm --minify",
    "build:node-api": "npx spago build -p cardano-addresses && npx esbuild node/src/index.js --bundle --platform=node --format=esm --outfile=node/dist/index.js"
  },
  "devDependencies": {
    "@bjorn3/browser_wasi_shim": "^0.4.2",
    "@noble/hashes": "^1.7.0",
    "@scure/base": "^1.2.0",
    "@scure/bip39": "^1.5.0",
    "@playwright/test": "1.54.1",
    "bech32": "^2.0.0",
    "esbuild": "^0.24.0",
    "events": "^3.3.0",
    "purescript": "^0.15.16",
    "purs-tidy": "^0.11.1",
    "serve": "^14.2.4",
    "spago": "^1.0.4"
  }
}
