{
  "name": "@lambdasistemi/cardano-swiss-knife",
  "version": "0.1.2",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "types": "./node/dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./node/dist/index.d.ts",
      "import": "./node/dist/index.js"
    }
  },
  "bin": {
    "csk": "./node/dist/csk.mjs"
  },
  "files": [
    "node/dist"
  ],
  "scripts": {
    "build:lib": "npx spago build -p cardano-addresses",
    "test": "npx spago test -p cardano-addresses-test",
    "bundle:lib": "npx esbuild output/Cardano.Address/index.js --bundle --outfile=dist/cardano-addresses.js --format=esm --minify",
    "build:node-api": "npx spago build -p cardano-addresses && npx esbuild node/src/index.js --bundle --platform=node --format=esm --outfile=node/dist/index.js && cp node/src/index.d.ts node/dist/index.d.ts && npx esbuild cli/csk.mjs --bundle --platform=node --format=esm --outfile=node/dist/csk.mjs",
    "docs:api": "typedoc",
    "test:package": "node --test node/test/package-smoke.mjs"
  },
  "dependencies": {
    "@bjorn3/browser_wasi_shim": "^0.4.2",
    "@noble/hashes": "^1.7.0",
    "@scure/base": "^1.2.0",
    "@scure/bip39": "^1.5.0",
    "age-encryption": "^0.3.0",
    "bech32": "^2.0.0",
    "events": "^3.3.0"
  },
  "devDependencies": {
    "@playwright/test": "1.54.1",
    "esbuild": "^0.24.0",
    "eslint": "10.7.0",
    "eslint-plugin-jsdoc": "63.2.0",
    "fast-check": "4.9.0",
    "purescript": "^0.15.16",
    "purs-tidy": "^0.11.1",
    "serve": "^14.2.4",
    "spago": "^1.0.4",
    "typedoc": "0.28.20",
    "typedoc-plugin-markdown": "4.12.0",
    "typescript": "5.9.3"
  }
}
