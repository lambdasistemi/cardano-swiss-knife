    "events": "^3.3.0"
  },
  "devDependencies": {
    "@playwright/test": "1.54.1",
    "esbuild": "^0.24.0",
    "purescript": "^0.15.16",
    "purs-tidy": "^0.11.1",
    "serve": "^14.2.4",
    "spago": "^1.0.4"
